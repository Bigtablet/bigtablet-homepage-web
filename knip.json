{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/app/**/{page,layout,loading,error,not-found,sitemap,robots,route,template,default,global-error,icon,apple-icon,opengraph-image,twitter-image}.{ts,tsx,js,jsx}",
		"src/app/global.css",
