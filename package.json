{
	"name": "bigtablet-homepage-web",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build --turbopack",
		"start": "next start",
		"lint": "biome check",
		"format": "biome format --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"type-check": "tsc --noEmit",
		"deadcode": "knip --no-progress",
		"e2e": "playwright test",
		"e2e:start": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && node .next/standalone/server.js",
		"e2e:ui": "playwright test --ui",
		"analyze": "ANALYZE=true next build",
		"prepare": "husky"
	},
	"dependencies": {
		"@bigtablet/design-system": "1.22.0",
		"@gsap/react": "^2.1.2",
		"@hookform/resolvers": "^5.4.0",
		"@next/bundle-analyzer": "^16.2.6",
		"@opentelemetry/api": "^1.9.1",
		"@sentry/nextjs": "^10.52.0",
		"@tanstack/react-query": "^5.100.10",
		"@vercel/otel": "^2.1.2",
		"axios": "^1.16.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"gsap": "^3.15.0",
		"lucide-react": "^1.14.0",
		"next": "^16.2.6",
		"next-intl": "^4.11.1",
		"react": "^19.2.6",
		"react-datepicker": "^9.1.0",
		"react-dom": "^19.2.6",
		"react-error-boundary": "^6.1.1",
		"react-hook-form": "^7.75.0",
		"react-markdown": "^10.1.0",
		"remark-breaks": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"sass": "^1.99.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@biomejs/biome": "^2.4.12",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/types": "^20.5.0",
		"@playwright/test": "^1.59.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"@vitest/coverage-v8": "^4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"knip": "^6.12.2",
		"msw": "^2.14.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vitest": "^4.1.4"
	},
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"pnpm": {
		"overrides": {
			"postcss@<8.5.10": "^8.5.10",
			"fast-uri@<3.1.2": "^3.1.2"
		}
	}
}
